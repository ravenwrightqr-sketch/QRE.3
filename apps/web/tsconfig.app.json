{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "types": ["vite/client"],

    "skipLibCheck": true,

    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",

    "noEmit": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}